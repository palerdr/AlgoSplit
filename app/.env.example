# Local web development. Production web deliberately uses same-origin Vercel
# rewrites; native production receives its API URL from eas.json.
# For Expo Go on a physical phone, put the deployed API URL in .env.local
# (which overrides this file) — localhost is unreachable from the device.
# Expo Go is suitable for email/password testing; Google OAuth needs the
# AlgoSplit development client so the algosplit:// callback belongs to the app.
# See "Running on a Phone" in the root README.
EXPO_PUBLIC_ALGOSPLIT_API=http://localhost:8000

# The app fetches the public Supabase URL and publishable key from
# GET /auth/social-config. Never put a Supabase secret key, Google client
# secret, Apple signing key, or Apple client secret in this file.

# Use the canonical production web callback when it is known. The native
# defaults are generated from the existing algosplit scheme, but set these
# explicitly in build configuration and keep identity values identical to the
# backend's AUTH_IDENTITY_*_CALLBACK_URL values.
# EXPO_PUBLIC_ALGOSPLIT_OAUTH_WEB_CALLBACK_URL=https://your-web-app.example/oauth/callback
# EXPO_PUBLIC_ALGOSPLIT_OAUTH_NATIVE_CALLBACK_URL=algosplit://oauth/callback
# EXPO_PUBLIC_ALGOSPLIT_IDENTITY_WEB_CALLBACK_URL=https://your-web-app.example/identity/callback
# EXPO_PUBLIC_ALGOSPLIT_IDENTITY_NATIVE_CALLBACK_URL=algosplit://identity/callback

# Optional override for the in-app public privacy-policy link.
# EXPO_PUBLIC_PRIVACY_POLICY_URL=https://your-domain.example/privacy
