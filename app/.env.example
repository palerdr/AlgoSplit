# AlgoSplit refreshed frontend
#
# The app is local-first: everything works offline on the ported TS engine.
# Point this at a running AlgoSplit backend (backend/main.py, e.g. uvicorn on
# port 8000) and analysis features upgrade to the server engine — same
# request/response contract as the legacy frontend.
EXPO_PUBLIC_ALGOSPLIT_API=http://localhost:8000
