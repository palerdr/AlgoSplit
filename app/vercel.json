{
  "installCommand": "npm install",
  "buildCommand": "npm run build:web",
  "outputDirectory": "dist",
  "framework": null,
  "env": {
    "NODE_OPTIONS": "--max-old-space-size=4096"
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://algosplit-api-staging.vercel.app/api/:path*" },
    { "source": "/auth/:path*", "destination": "https://algosplit-api-staging.vercel.app/auth/:path*" },
    { "source": "/health", "destination": "https://algosplit-api-staging.vercel.app/health" },
    { "source": "/keepalive", "destination": "https://algosplit-api-staging.vercel.app/keepalive" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/((?!api/|auth/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/share/(.*)",
      "headers": [
        { "key": "Referrer-Policy", "value": "no-referrer" },
        { "key": "Cache-Control", "value": "no-store" },
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/_expo/static/js/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
