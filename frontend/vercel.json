{
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://algosplit.onrender.com/api/:path*" },
    { "source": "/auth/:path*", "destination": "https://algosplit.onrender.com/auth/:path*" },
    { "source": "/health", "destination": "https://algosplit.onrender.com/health" },
    { "source": "/keepalive", "destination": "https://algosplit.onrender.com/keepalive" },
    { "source": "/((?!api/|auth/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
